# Copy this file to .env and adjust values before first run.

APP_NAME="SMP Karting Race Control"
DEBUG=false

HOST=0.0.0.0
PORT=8000

# IMPORTANT: Generate a random string before first race.
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-first-race

INVITE_TOKEN_EXPIRE_HOURS=72

DATABASE_URL=sqlite+aiosqlite:///./smp_karting.db

AUDIO_STORAGE_DIR=audio_storage

# "small" is fast; "medium" is more accurate but slower on CPU
WHISPER_MODEL=small
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cpu
